{
  "@context": {
    "adms": "http://www.w3.org/ns/adms#",
    "cpsv": "http://purl.org/vocab/cpsv#",
    "dct": "http://purl.org/dc/terms/",
    "dpv": "https://w3id.org/dpv#",
    "ext": "http://mu.semte.ch/vocabularies/ext/",
    "icr": "http://lblod.data.gift/vocabularies/informationclassification/",
    "nie": "http://www.semanticdesktop.org/ontologies/2007/01/19/nie#",
    "prov": "http://www.w3.org/ns/prov#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "@type": "dpv:Process",
    "title": "dct:title",
    "description": "dct:description",
    "email": "schema:email",
    "created": "dct:created",
    "modified": "dct:modified",
    "status": "adms:status",
    "confidentiality-score": "icr:confidentialityScore",
    "integrity-score": "icr:integrityScore",
    "availability-score": "icr:availabilityScore",
    "contains-personal-data": "icr:containsPersonalData",
    "contains-professional-data": "icr:containsProfessionalData",
    "contains-sensitive-personal-data": "icr:containsSensitivePersonalData",
    "additional-information": "icr:additionalInformation",
    "has-control-measure": "icr:hasControlMeasure",
    "is-blueprint": "icr:isBlueprint",
    "publisher": {
      "@id": "dct:publisher",
      "@type": "@id"
    },
    "process-statistics": {
      "@id": "ext:hasStatistics",
      "@type": "@id"
    },
    "linked-concept": {
      "@id": "dct:source",
      "@type": "@id"
    },
    "conceptualProcess": {
      "@id": "dct:source",
      "@type": "@id"
    },
    "files": {
      "@id": "nie:hasPart",
      "@type": "@id",
      "@container": "@set",
      "@reverse": "nie:isPartOf"
    },
    "ipdc-products": {
      "@id": "cpsv:follows",
      "@type": "@id",
      "@container": "@set",
      "@reverse": "cpsv:follows"
    },
    "relevant-administrative-units": {
      "@id": "icr:isRelevantForAdministrativeUnit",
      "@type": "@id",
      "@container": "@set"
    },
    "information-assets": {
      "@id": "icr:hasInformationAsset",
      "@type": "@id",
      "@container": "@set"
    },
    "linked-blueprints": {
      "@id": "prov:wasInfluencedBy",
      "@type": "@id",
      "@container": "@set"
    },
    "users": {
      "@id": "prov:usedBy",
      "@type": "@id",
      "@container": "@set"
    },
    "links": {
      "@id": "rdfs:seeAlso",
      "@type": "@id",
      "@container": "@set"
    }
  }
}