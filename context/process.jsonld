{
  "@context": {
    "@version": 1.1,
    "@base": "http://data.lblod.info/processes/",
    "adms": "http://www.w3.org/ns/adms#",
    "besluit": "http://data.vlaanderen.be/ns/besluit#",
    "cpsv": "http://purl.org/vocab/cpsv#",
    "dct": "http://purl.org/dc/terms/",
    "dpv": "https://w3id.org/dpv#",
    "ext": "http://mu.semte.ch/vocabularies/ext/",
    "icr": "http://lblod.data.gift/vocabularies/informationclassification/",
    "nie": "http://www.semanticdesktop.org/ontologies/2007/01/19/nie#",
    "nfo": "http://www.semanticdesktop.org/ontologies/2007/03/22/nfo#",
    "oph": "http://lblod.data.gift/vocabularies/openproceshuis/",
    "organisatie": "http://lblod.data.gift/vocabularies/organisatie/",
    "prov": "http://www.w3.org/ns/prov#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "type": "@type",
    "Process": "dpv:Process",
    "title": {
      "@id": "dct:title",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "dct:description",
      "@type": "xsd:string"
    },
    "email": {
      "@id": "schema:email",
      "@type": "xsd:string"
    },
    "created": {
      "@id": "dct:created",
      "@type": "xsd:dateTime"
    },
    "modified": {
      "@id": "dct:modified",
      "@type": "xsd:dateTime"
    },
    "status": {
      "@id": "adms:status",
      "@type": "@id"
    },
    "confidentiality-score": {
      "@id": "icr:confidentialityScore",
      "@type": "xsd:integer"
    },
    "integrity-score": {
      "@id": "icr:integrityScore",
      "@type": "xsd:integer"
    },
    "availability-score": {
      "@id": "icr:availabilityScore",
      "@type": "xsd:integer"
    },
    "contains-personal-data": {
      "@id": "icr:containsPersonalData",
      "@type": "xsd:boolean"
    },
    "contains-professional-data": {
      "@id": "icr:containsProfessionalData",
      "@type": "xsd:boolean"
    },
    "contains-sensitive-personal-data": {
      "@id": "icr:containsSensitivePersonalData",
      "@type": "xsd:boolean"
    },
    "additional-information": {
      "@id": "icr:additionalInformation",
      "@type": "xsd:string"
    },
    "has-control-measure": {
      "@id": "icr:hasControlMeasure",
      "@type": "@id"
    },
    "is-blueprint": {
      "@id": "icr:isBlueprint",
      "@type": "xsd:boolean"
    },
    "publisher": {
      "@id": "dct:publisher",
      "@type": "@id",
      "@context": {
        "Bestuurseenheid": "besluit:Bestuurseenheid"
      }
    },
    "process-statistics": {
      "@id": "ext:hasStatistics",
      "@type": "@id"
    },
    "linked-concept": {
      "@id": "dct:source",
      "@type": "@id",
      "@context": {
        "ConceptueelProces": "oph:ConceptueelProces"
      }
    },
    "diagrams": {
      "@reverse": "nie:isPartOf",
      "@container": "@set",
      "@type": "@id",
      "@context": {
        "FileDataObject": "nfo:FileDataObject"
      }
    },
    "attachments": {
      "@reverse": "nie:isPartOf",
      "@container": "@set",
      "@type": "@id",
      "@context": {
        "FileDataObject": "nfo:FileDataObject"
      }
    },
    "ipdc-products": {
      "@reverse": "cpsv:follows",
      "@container": "@set"
    },
    "relevant-administrative-units": {
      "@id": "icr:isRelevantForAdministrativeUnit",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "BestuurseenheidClassificatieCode": "organisatie:BestuurseenheidClassificatieCode"
      }
    },
    "information-assets": {
      "@id": "icr:hasInformationAsset",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "Concept": "skos:Concept"
      }
    },
    "linked-blueprints": {
      "@id": "prov:wasInfluencedBy",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "Process": "dpv:Process"
      }
    },
    "users": {
      "@id": "prov:usedBy",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "Bestuurseenheid": "besluit:Bestuurseenheid"
      }
    },
    "links": {
      "@id": "rdfs:seeAlso",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "Bookmark": "nfo:Bookmark"
      }
    }
  }
}