{
  "@context": {
    "@version": 1.1,
    "adms": "http://www.w3.org/ns/adms#",
    "cpsv": "http://purl.org/vocab/cpsv#",
    "dct": "http://purl.org/dc/terms/",
    "dpv": "https://w3id.org/dpv#",
    "ext": "http://mu.semte.ch/vocabularies/ext/",
    "icr": "http://lblod.data.gift/vocabularies/informationclassification/",
    "nie": "http://www.semanticdesktop.org/ontologies/2007/01/19/nie#",
    "prov": "http://www.w3.org/ns/prov#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "@type": "dpv:Process",
    "@base": "http://data.lblod.info/processes/",
    "title": {
      "@id": "dct:title",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "dct:description",
      "@type": "xsd:string"
    },
    "email": {
      "@id": "schema:email",
      "@type": "xsd:string"
    },
    "created": {
      "@id": "dct:created",
      "@type": "xsd:dateTime"
    },
    "modified": {
      "@id": "dct:modified",
      "@type": "xsd:dateTime"
    },
    "status": {
      "@id": "adms:status",
      "@type": "@id"
    },
    "confidentiality-score": {
      "@id": "icr:confidentialityScore",
      "@type": "xsd:integer"
    },
    "integrity-score": {
      "@id": "icr:integrityScore",
      "@type": "xsd:integer"
    },
    "availability-score": {
      "@id": "icr:availabilityScore",
      "@type": "xsd:integer"
    },
    "contains-personal-data": {
      "@id": "icr:containsPersonalData",
      "@type": "xsd:boolean"
    },
    "contains-professional-data": {
      "@id": "icr:containsProfessionalData",
      "@type": "xsd:boolean"
    },
    "contains-sensitive-personal-data": {
      "@id": "icr:containsSensitivePersonalData",
      "@type": "xsd:boolean"
    },
    "additional-information": {
      "@id": "icr:additionalInformation",
      "@type": "xsd:string"
    },
    "has-control-measure": {
      "@id": "icr:hasControlMeasure",
      "@type": "@id"
    },
    "is-blueprint": {
      "@id": "icr:isBlueprint",
      "@type": "xsd:boolean"
    },
    "publisher": {
      "@id": "dct:publisher",
      "@type": "@id"
    },
    "process-statistics": {
      "@id": "ext:hasStatistics",
      "@type": "@id"
    },
    "linked-concept": {
      "@id": "dct:source",
      "@type": "@id"
    },
    "conceptualProcess": {
      "@id": "dct:source",
      "@type": "@id"
    },
    "files": {
      "@id": "nie:hasPart",
      "@type": "@id",
      "@container": "@set",
      "@reverse": "nie:isPartOf"
    },
    "ipdc-products": {
      "@id": "cpsv:follows",
      "@type": "@id",
      "@container": "@set",
      "@reverse": "cpsv:follows"
    },
    "relevant-administrative-units": {
      "@id": "icr:isRelevantForAdministrativeUnit",
      "@type": "@id",
      "@container": "@set"
    },
    "information-assets": {
      "@id": "icr:hasInformationAsset",
      "@type": "@id",
      "@container": "@set"
    },
    "linked-blueprints": {
      "@id": "prov:wasInfluencedBy",
      "@type": "@id",
      "@container": "@set"
    },
    "users": {
      "@id": "prov:usedBy",
      "@type": "@id",
      "@container": "@set"
    },
    "links": {
      "@id": "rdfs:seeAlso",
      "@type": "@id",
      "@container": "@set"
    }
  }
}