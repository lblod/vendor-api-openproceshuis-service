{
  "@context": {
    "@version": 1.1,
    "adms": "http://www.w3.org/ns/adms#",
    "dbpedia": "http://dbpedia.org/ontology/",
    "dct": "http://purl.org/dc/terms/",
    "dpv": "https://w3id.org/dpv#",
    "nfo": "http://www.semanticdesktop.org/ontologies/2007/03/22/nfo#",
    "nie": "http://www.semanticdesktop.org/ontologies/2007/01/19/nie#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "@type": "nfo:http://www.semanticdesktop.org/ontologies/2007/03/22/nfo#",
    "@base": "http://data.lblod.info/files/",
    "name": {
      "@id": "nfo:fileName",
      "@type": "xsd:string"
    },
    "format": {
      "@id": "dct:format",
      "@type": "xsd:string"
    },
    "size": {
      "@id": "nfo:fileSize",
      "@type": "xsd:integer"
    },
    "extension": {
      "@id": "dbpedia:fileExtension",
      "@type": "xsd:string"
    },
    "created": {
      "@id": "dct:created",
      "@type": "xsd:dateTime"
    },
    "modified": {
      "@id": "dct:modified",
      "@type": "xsd:dateTime"
    },
    "status": {
      "@id": "adms:status",
      "@type": "@id"
    },
    "download": {
      "@id": "nie:dataSource",
      "@type": "@id",
      "@context": {
        "@type": "nfo:FileDataObject"
      }
    },
    "process": {
      "@id": "nie:isPartOf",
      "@type": "@id",
      "@container": "@set",
      "@context": {
        "@type": "dpv:Process"
      }
    }
  }
}